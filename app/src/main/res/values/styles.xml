<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- App Theme - Dark -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#FFD50000</item>
        <item name="colorPrimaryDark">#FFB71C1C</item>
        <item name="colorAccent">#FFFF1744</item>
        <item name="android:colorBackground">#FF121212</item>
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">#FF000000</item>
        <item name="android:navigationBarColor">#FF000000</item>
        <item name="colorSurface">#FF1E1E1E</item>
        <item name="colorOnSurface">#FFFFFFFF</item>
        <item name="colorOnPrimary">#FFFFFFFF</item>
    </style>

    <style name="SplashTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/background_dark</item>
        <item name="android:statusBarColor">#FF000000</item>
        <item name="android:navigationBarColor">#FF000000</item>
    </style>

    <style name="CardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">#FF1E1E1E</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <style name="ActionButton" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">#FFD50000</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textColor">#FFFFFFFF</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ActionButtonOutline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">#FFD50000</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textColor">#FFD50000</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
